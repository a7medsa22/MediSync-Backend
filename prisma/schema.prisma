generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String?
  firstName         String
  lastName          String
  phone             String?
  nationalId        String?        @unique
  idCardImage       String?
  role              UserRole       @default(PATIENT)
  status            UserStatus
  rejectionReason   String?
  isActive          Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  approvedAt        DateTime?
  approvedBy        String?
  isProfileComplete Boolean        @default(false)
  registrationStep  Int            @default(0)
  authProvider      AuthProvider   @default(LOCAL)
  profilePhoto      String?
  providerId        String?
  timezone          String?        @default("Africa/Cairo")
  tokens            AuthToken[]
  doctor            Doctor?
  sendMessages      Message[]
  notifications     Notification[]
  otps              Otp[]
  patient           Patient?
  fileAuditLogs     FileAuditLog[]

  @@index([status])
  @@index([isActive])
  @@map("users")
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

model AuthToken {
  id         String    @id @default(uuid())
  userId     String
  type       TokenType
  isRevoked  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  tokenHash  String
  deviceName String?
  ipAddress  String?
  userAgent  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  message   String
  type      NotificationType @default(CONNECTION_REQUEST)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  metadata  Json?
  title     String
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, isRead])
  @@map("notifications")
}

model Patient {
  id                    String                    @id @default(uuid())
  userId                String                    @unique
  dateOfBirth           DateTime?
  gender                String?
  address               String?
  bloodType             String?
  allergies             String?
  chronicDiseases       String?
  city                  String?
  currentMedications    String?
  governorate           String?
  height                Float?
  phone                 String?
  profilePhoto          String?
  weight                Float?
  emergencyContactName  String?
  emergencyContactPhone String?
  insuranceNumber       String?
  insuranceProvider     String?
  medicalRecords        MedicalRecord[]
  appointments          Appointment[]
  connections           DoctorPatientConnection[]
  followUpRequests      FollowUpRequest[]
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptionRenewals  PrescriptionRenewal[]
  prescriptions         Prescription[]
  qrTokens              QrToken[]
  reviews               DoctorReview[]

  @@index([userId])
  @@map("patients")
}

model Specialization {
  id          String   @id @default(uuid())
  name        String   @unique
  nameAr      String?
  description String?
  doctors     Doctor[]

  @@map("specializations")
}

model Doctor {
  id                    String                    @id @default(uuid())
  userId                String                    @unique
  specializationId      String?
  licenseNumber         String?                   @unique
  bio                   String?
  education             String?
  rating                Float?                    @default(0)
  reviewCount           Int                       @default(0)
  yearsOfExperience     Int?
  medicalRecords        MedicalRecord[]
  appointments          Appointment[]
  availabilities        DoctorAvailability[]
  breaks                DoctorBreak[]
  daysOff               DoctorDayOff[]
  connections           DoctorPatientConnection[]
  specialization        Specialization?           @relation(fields: [specializationId], references: [id])
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  followUpRequests      FollowUpRequest[]
  prescriptionTemplates PrescriptionTemplate[]
  prescriptions         Prescription[]
  qrTokens              QrToken[]
  clinics               Clinic[]
  reviews               DoctorReview[]
  insurances            DoctorInsurance[]

  @@map("doctors")
}

model DoctorPatientConnection {
  id             String           @id @default(uuid())
  doctorId       String
  patientId      String
  connectionType ConnectionType?
  status         ConnectionStatus @default(ACTIVE)
  connectedAt    DateTime         @default(now())
  lastActivityAt DateTime?
  unreadCount    Int?
  lastMessageAt  DateTime?
  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  chat           Chat?
  doctor         Doctor           @relation(fields: [doctorId], references: [id])
  patient        Patient          @relation(fields: [patientId], references: [id])
  prescriptions  Prescription[]

  @@unique([doctorId, patientId])
  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@map("doctor_patient_connections")
}

model FollowUpRequest {
  id                String        @id @default(uuid())
  patientId         String
  doctorId          String
  prescriptionImage String
  status            RequestStatus @default(PENDING)
  rejectionReason   String?
  requestDate       DateTime      @default(now())
  responseDate      DateTime?
  respondedBy       String?
  notes             String?
  doctor            Doctor        @relation(fields: [doctorId], references: [id])
  patient           Patient       @relation(fields: [patientId], references: [id])

  @@map("follow_up_requests")
}

model MedicalRecord {
  id                 String     @id @default(uuid())
  patientId          String     
  fileName           String
  fileUrl            String
  recordType         RecordType @default(OTHER)
  fileSize           BigInt
  mimeType           String
  title              String
  description        String?    @db.Text
  recordDate         DateTime   @default(now())
  uploadedBy         String     
  doctorId           String?
  version            Int        @default(1)
  isEncrypted        Boolean    @default(true)
  encryptionMetadata Json // {algorithm, iv, authTag, keyId}
  isVerified         Boolean    @default(false)
  verifyNotes        String?    
  clinicId           String?    
  connectionId       String?    
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  
  doctor     Doctor?                   @relation(fields: [doctorId], references: [id])
  patient    Patient                   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  connection DoctorPatientConnection? @relation(fields: [connectionId], references: [id])
  shares     RecordShare[]
  auditLogs  FileAuditLog[]

  @@index([patientId])
  @@index([clinicId])
  @@map("medical_records")
}

model RecordShare {
  id               String   @id @default(uuid())
  recordId         String   
  sharedWithUserId String   
  sharedBy         String   
  canDownload      Boolean  @default(true)
  canShare         Boolean  @default(false)
  expiresAt        DateTime
  sharedAt         DateTime @default(now())

  medicalRecord MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([sharedWithUserId])
  @@index([recordId])
  @@map("record_shares")
}

model FileAuditLog {
  id        String      @id @default(uuid()) 
  recordId  String      
  userId    String      
  action    AuditAction
  ipAddress String
  userAgent String
  timestamp DateTime    @default(now())

  medicalRecord MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@map("file_audit_logs")
}

enum AuditAction {
  VIEW
  DOWNLOAD
  SHARE
  DELETE
  UPLOAD
}


model Prescription {
  id                      String                   @id @default(uuid())
  connectionId            String
  doctorId                String
  patientId               String
  prescribedAt            DateTime                 @default(now())
  notes                   String?
  updateAt                DateTime                 @updatedAt
  expireAt                DateTime?
  maxRenewals             Int                      @default(3)
  parentPrescriptionId    String?
  renewalCount            Int                      @default(0)
  status                  PrescriptionStatus       @default(ACTIVE)
  isRenewal               Boolean                  @default(false)
  history                 PrescriptionHistory[]
  prescriptionMedications PrescriptionMedication[]
  renewals                PrescriptionRenewal[]
  connection              DoctorPatientConnection  @relation(fields: [connectionId], references: [id])
  doctor                  Doctor                   @relation(fields: [doctorId], references: [id])
  patient                 Patient                  @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([expireAt])
  @@map("prescriptions")
}

model PrescriptionMedication {
  id             String       @id @default(uuid())
  prescriptionId String
  drugName       String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  sideEffects    String?
  warnings       String?
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
  @@map("prescription_medications")
}

model PrescriptionTemplate {
  id          String               @id @default(uuid())
  doctorId    String
  name        String
  notes       String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  usageCount  Int                  @default(0)
  doctor      Doctor               @relation(fields: [doctorId], references: [id])
  medications TemplateMedication[]

  @@index([doctorId])
  @@map("prescription_templates")
}

model TemplateMedication {
  id           String               @id @default(uuid())
  templateId   String
  drugName     String
  dosage       String
  frequency    String
  duration     String
  instructions String?
  sideEffects  String?
  warnings     String?
  template     PrescriptionTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@map("template_medications")
}

model PrescriptionRenewal {
  id              String        @id @default(uuid())
  prescriptionId  String
  patientId       String
  status          RenewalStatus @default(PENDING)
  requestedAt     DateTime      @default(now())
  respondedAt     DateTime?
  respondedBy     String?
  rejectionReason String?
  renewalCount    Int           @default(1)
  maxRenewals     Int           @default(3)
  patient         Patient       @relation(fields: [patientId], references: [id])
  prescription    Prescription  @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
  @@index([patientId])
  @@index([status])
  @@map("prescription_renewals")
}

model PrescriptionHistory {
  id             String              @id @default(uuid())
  prescriptionId String
  previousStatus PrescriptionStatus?
  newStatus      PrescriptionStatus
  changedBy      String
  changedAt      DateTime            @default(now())
  action         PrescriptionAction
  reason         String?
  metadata       Json?
  prescription   Prescription        @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@index([changedAt])
  @@map("prescription_history")
}

model QrToken {
  id        String    @id @default(uuid())
  doctorId  String
  token     String    @unique
  type      String    @default("CONNECTION")
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient   Patient?  @relation(fields: [usedBy], references: [id])

  @@index([token])
  @@index([doctorId])
  @@index([expiresAt])
  @@map("qr_tokens")
}

model Chat {
  id                 String                  @id @default(uuid())
  connectionId       String                  @unique
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  lastMessageAt      DateTime?
  lastMessagePreview String?                 @db.VarChar(255)
  connection         DoctorPatientConnection @relation(fields: [connectionId], references: [id])
  messages           Message[]

  @@index([connectionId])
  @@index([lastMessageAt])
  @@map("chats")
}

model Message {
  id           String    @id @default(uuid())
  chatId       String
  senderId     String
  content      String
  messageType  String    @default("TEXT")
  isRead       Boolean   @default(false)
  readAt       DateTime?
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  senderAvatar String?
  senderName   String?
  senderRole   String?
  chat         Chat      @relation(fields: [chatId], references: [id])
  sender       User      @relation(fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isRead])
  @@map("messages")
}

model DoctorAvailability {
  id                    String    @id @default(uuid())
  doctorId              String
  dayOfWeek             DayOfWeek
  startTime             Int
  endTime               Int
  slotDuration          Int       @default(30)
  maxAppointmentsPerDay Int       @default(10)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  doctor                Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime, endTime])
  @@index([doctorId])
  @@index([dayOfWeek])
  @@map("doctor_availability")
}

model DoctorBreak {
  id        String    @id @default(uuid())
  doctorId  String
  dayOfWeek DayOfWeek
  startTime Int
  endTime   Int
  reason    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([dayOfWeek])
  @@map("doctor_breaks")
}

model DoctorDayOff {
  id        String   @id @default(uuid())
  doctorId  String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date])
  @@index([doctorId])
  @@map("doctor_days_off")
}

model Appointment {
  id                 String                  @id @default(uuid())
  doctorId           String
  patientId          String
  connectionId       String
  type               AppointmentType         @default(IN_CLINIC)
  status             AppointmentStatus       @default(PENDING)
  reason             String?
  notes              String?
  startTime          DateTime
  endTime            DateTime
  clinicId           String?
  roomNumber         String?
  meetingLink        String?
  isReminderSent24h  Boolean                 @default(false)
  isReminderSent1h   Boolean                 @default(false)
  prescriptionId     String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?
  connection         DoctorPatientConnection @relation(fields: [connectionId], references: [id])
  doctor             Doctor                  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient            Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic             Clinic?                 @relation(fields: [clinicId], references: [id])

  @@unique([doctorId, startTime])
  @@index([doctorId])
  @@index([patientId])
  @@index([connectionId])
  @@index([startTime])
  @@index([status])
  @@index([status, startTime])
  @@map("appointments")
}

model InsuranceProvider {
  id               String            @id @default(uuid())
  name             String
  code             String            @unique
  description      String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  doctorInsurances DoctorInsurance[]
  clinicInsurances ClinicInsurance[]

  @@map("insurance_providers")
}

model Clinic {
  id                 String             @id @default(uuid())
  doctorId           String
  doctor             Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  name               String
  address            String
  city               String
  governorate        String
  zipCode            String?
  phone              String
  email              String
  website            String?
  licenseNumber      String
  licenseDoc         String // S3 URL String
  consultationFee    Decimal            @db.Decimal(10, 2)
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String?
  rejectionReason    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  insurances         ClinicInsurance[]
  appointments       Appointment[]

  @@index([verificationStatus])
  @@index([city, verificationStatus])
  @@map("clinics")
}

model DoctorReview {
  id          String   @id @default(uuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  rating      Int      @db.Integer
  comment     String?  @db.Text
  isAnonymous Boolean  @default(false)
  isFlagged   Boolean  @default(false)
  flagReason  String?  @db.VarChar
  isApproved  Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([doctorId, patientId])
  @@index([isFlagged])
  @@map("doctor_reviews")
}

model DoctorInsurance {
  id          String            @id @default(uuid())
  doctorId    String
  doctor      Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  insuranceId String
  insurance   InsuranceProvider @relation(fields: [insuranceId], references: [id], onDelete: Cascade)
  isVerified  Boolean           @default(false)
  createdAt   DateTime          @default(now())

  @@unique([doctorId, insuranceId])
  @@map("doctor_insurances")
}

model ClinicInsurance {
  id          String            @id @default(uuid())
  clinicId    String
  clinic      Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  insuranceId String
  insurance   InsuranceProvider @relation(fields: [insuranceId], references: [id], onDelete: Cascade)
  isVerified  Boolean           @default(false)
  createdAt   DateTime          @default(now())

  @@unique([clinicId, insuranceId])
  @@map("clinic_insurances")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

enum UserStatus {
  INIT
  PENDING_EMAIL_VERIFICATION
  EMAIL_VERIFIED
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_ADMIN_APPROVAL
}

enum TokenType {
  ACCESS
  REFRESH
}

enum AuthProvider {
  EMAIL
  GOOGLE
  FACEBOOK
  APPLE
  LOCAL
}

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  QR_SCANNED
  NEW_MESSAGE
  NEW_CONNECTION
  NEW_CHAT_MESSAGE
  APPOINTMENT_BOOKED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED
  PAYMENT_COMPLETED
  PRESCRIPTION_RENEWAL_REQUEST
  PRESCRIPTION_EXPIRY_WARNING
  NEW_PRESCRIPTION
  PRESCRIPTION_CANCELLED
  PRESCRIPTION_RENEWAL_APPROVED
  PRESCRIPTION_RENEWAL_REJECTED
  PRESCRIPTION_EXPIRY_REMINDER
  CLINIC_VERIFIED
  CLINIC_REJECTED
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RecordType {
  LAB_RESULT
  XRAY
  SCAN
  MEDICAL_REPORT
  VACCINATION
  OTHER
}

enum ConnectionType {
  SCANNED
  REQUESTED
  QR_CODE
  ADMIN_ADDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  IN_CLINIC
  REMOTE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PrescriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum RenewalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PrescriptionAction {
  CREATE
  RENEW
  EXPIRE
  CANCEL
  VIEW
}
